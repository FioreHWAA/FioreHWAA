<script>
  function calculateSum() {
    // group1
    let sum1 = 0;
    document.querySelectorAll('select.group1').forEach(select => {
      const value = parseFloat(select.value);
      if (!isNaN(value)) sum1 += value;
    });
    document.getElementById('result').innerText = '총합: ' + sum1.toFixed(2);

    // group2
    let sum2 = 0;
    document.querySelectorAll('select.group2').forEach(select => {
      const value = parseFloat(select.value);
      if (!isNaN(value)) sum2 += value;
    });
    document.getElementById('result2').innerText = '이미 산거: ' + sum2.toFixed(2);

    let finalSum = sum1 + sum2;
    document.getElementById('result3').innerText = '최종 합계: ' + finalSum.toFixed(2);
  }

  document.addEventListener('DOMContentLoaded', function() {
    calculateSum();

    document.querySelectorAll('select').forEach(select => {
      select.addEventListener('change', calculateSum);
    });
  });
</script>

