<script>
  function calculateSum() {
    let sum = 0;
    const selectElements = document.querySelectorAll('select[id^="select"]');

    selectElements.forEach(selectElement => {
      const value = parseFloat(selectElement.value);
      if (!isNaN(value)) {
        sum += value;
      }
    });

    document.getElementById('result').innerText = '총합: ' + sum.toFixed(2);
  }

  document.addEventListener('DOMContentLoaded', function() {
    calculateSum();

    const selectElements = document.querySelectorAll('select[id^="select"]');
    selectElements.forEach(select => {
      select.addEventListener('change', calculateSum);
    });
  });
</script>

